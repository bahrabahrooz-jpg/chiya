{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/dashboard/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/icon/**",
              "components/navigation/**",
              "components/realestate/**",
              "ui_kits/mobile/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Hanken Grotesk|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Hanken Grotesk, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|avatar|agency|verified|rating|reviews|listings|sales|experience|layout|onCall|onMessage|key|ref|className|style|children)$/]",
        "message": "<AgentCard> doesn't accept that prop. Declared props: name, avatar, agency, verified, rating, reviews, listings, sales, experience, layout, onCall, onMessage."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentCard'] > JSXAttribute[name.name='layout'] > Literal[value!=/^(?:stack|row)$/]",
        "message": "<AgentCard> layout must be one of 'stack' | 'row'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnalyticsDatum'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|a|b|key|ref|className|style|children)$/]",
        "message": "<AnalyticsDatum> doesn't accept that prop. Declared props: label, a, b."
      },
      {
        "selector": "JSXOpeningElement[name.name='ApptDate'] > JSXAttribute > JSXIdentifier[name!=/^(?:dow|day|key|ref|className|style|children)$/]",
        "message": "<ApptDate> doesn't accept that prop. Declared props: dow, day."
      },
      {
        "selector": "JSXOpeningElement[name.name='ApprovalAgent'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|avatar|verified|key|ref|className|style|children)$/]",
        "message": "<ApprovalAgent> doesn't accept that prop. Declared props: name, avatar, verified."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|status|verified|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring, status, verified."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|dot|icon|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, size, dot, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|hierarchy|size|iconLeading|iconTrailing|iconOnly|loading|disabled|fullWidth|type|href|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, hierarchy, size, iconLeading, iconTrailing, iconOnly, loading, disabled, fullWidth, type, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Choice'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|description|disabled|key|ref|className|style|children)$/]",
        "message": "<Choice> doesn't accept that prop. Declared props: label, description, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='CardAgent'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|avatar|agency|verified|key|ref|className|style|children)$/]",
        "message": "<CardAgent> doesn't accept that prop. Declared props: name, avatar, agency, verified."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|variant|size|active|disabled|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, label, variant, size, active, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|required|size|iconLeading|iconTrailing|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, required, size, iconLeading, iconTrailing."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapPin'] > JSXAttribute > JSXIdentifier[name!=/^(?:x|y|price|active|cluster|key|ref|className|style|children)$/]",
        "message": "<MapPin> doesn't accept that prop. Declared props: x, y, price, active, cluster."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|subtitle|icon|size|children|footer|footerSpread|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: open, onClose, title, subtitle, icon, size, children, footer, footerSpread."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Modal> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|active|key|ref|className|style|children)$/]",
        "message": "<NavLink> doesn't accept that prop. Declared props: label, href, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='PropertyCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|price|period|title|address|beds|baths|area|areaUnit|status|featured|photoCount|favorite|onFavorite|href|key|ref|className|style|children)$/]",
        "message": "<PropertyCard> doesn't accept that prop. Declared props: image, price, period, title, address, beds, baths, area, areaUnit, status, featured, photoCount, favorite, onFavorite, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='PropertyGallery'] > JSXAttribute > JSXIdentifier[name!=/^(?:images|status|badges|maxThumbs|onExpand|className|key|ref|className|style|children)$/]",
        "message": "<PropertyGallery> doesn't accept that prop. Declared props: images, status, badges, maxThumbs, onExpand, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchSegment'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|icon|placeholder|key|ref|className|style|children)$/]",
        "message": "<SearchSegment> doesn't accept that prop. Declared props: label, value, icon, placeholder."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|delta|deltaDir|sub|icon|tone|spark|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, delta, deltaDir, sub, icon, tone, spark."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='deltaDir'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<StatCard> deltaDir must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|gold|info|success)$/]",
        "message": "<StatCard> tone must be one of 'brand' | 'gold' | 'info' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|header|align|numeric|sortable|render|key|ref|className|style|children)$/]",
        "message": "<TableColumn> doesn't accept that prop. Declared props: key, header, align, numeric, sortable, render."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<TableColumn> align must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|count|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label, icon, count."
      }
    ]
  },
