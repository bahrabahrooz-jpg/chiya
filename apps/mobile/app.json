{
  "expo": {
    "name": "Chiya",
    "slug": "chiya-mobile",
    "version": "0.1.0",
    "scheme": "chiya",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chiya.estate"
    },
    "android": {
      "package": "com.chiya.estate",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Chiya to access your photos to add listing images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
